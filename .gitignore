# Proteus auto backup directories
**/Project Backups/

# Office temporary lock files
**/~$*

# LaTeX intermediate build directory
**/doc/output/latex/build/

# LaTeX intermediate files
**/*.aux
**/*.log
**/*.out
**/*.toc
**/*.fls
**/*.fdb_latexmk
**/*.synctex.gz
**/*.xdv
**/*.lof
**/*.lot
**/*.bbl
**/*.blg
**/*.nav
**/*.snm
**/*.vrb
**/*.run.xml
**/*.tmp
.spec-workflow

# Root merge build output
/build_all/

# Proteus per-user workspace files
**/*.workspace

# Rendered preview images and duplicated build PDFs
**/doc/output/latex/build/preview/
**/doc/output/latex/build/*.pdf
